# ──────────────────────────────────────────────────────────────────
# SERVICE PORTS
# All ports are internal Docker service ports unless otherwise noted.
# NGINX_HTTP_PORT and NGINX_HTTPS_PORT are externally bound.
# ──────────────────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432

# ──────────────────────────────────────────────────────────────────
# FRONTEND
# ──────────────────────────────────────────────────────────────────
# Base URL of the API as seen by the browser (through Nginx)
NEXT_PUBLIC_API_BASE_URL=http://localhost:80

# ──────────────────────────────────────────────────────────────────
# BACKEND: SECURITY
# ──────────────────────────────────────────────────────────────────
# Minimum 32 random bytes, Base64-encoded (generate with: openssl rand -base64 32)
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_HOURS=24
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:80

# ──────────────────────────────────────────────────────────────────
# DATABASE (POSTGRESQL)
# ──────────────────────────────────────────────────────────────────
POSTGRES_DB=nod_db
POSTGRES_USER=nod_user
POSTGRES_PASSWORD=
# Async SQLAlchemy connection string — must use asyncpg driver
DATABASE_URL=postgresql+asyncpg://nod_user:changeme@db:5432/nod_db

# ──────────────────────────────────────────────────────────────────
# OPENSEARCH ENDPOINTS
# ──────────────────────────────────────────────────────────────────
OPENSEARCH_APPID_URL=https://10.90.150.108:9200
OPENSEARCH_TELEGRAF_URL=https://10.80.150.108:9200
OPENSEARCH_IPSEC_URL=https://10.90.150.108:9200
# Leave blank if OpenSearch has no authentication configured
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
# Number of connections in the async client pool per endpoint
OPENSEARCH_POOL_SIZE=10
# OpenSearch client request timeout in seconds
OPENSEARCH_REQUEST_TIMEOUT=10

# ──────────────────────────────────────────────────────────────────
# SITE CONFIGURATION (Anti-Wildcard Compliance — Rule Q-06)
# ──────────────────────────────────────────────────────────────────
# Comma-separated list of exact SD-WAN measurement_name values
TELEGRAF_SDWAN_SITES=Site_FGT-DC,Site_FGT-DRC,Site_FGT_Office
# Comma-separated list of exact SSL VPN measurement_name values
TELEGRAF_SSLVPN_SITES=Site_FGT-DC_SSLVPN,Site_FGT-DRC_SSLVPN

# ──────────────────────────────────────────────────────────────────
# ALERT ENGINE
# ──────────────────────────────────────────────────────────────────
# How often the alert evaluation job runs (seconds)
ALERT_POLL_INTERVAL_SECONDS=60
# Re-notify interval for sustained FIRING alerts (minutes)
ALERT_RENOTIFY_INTERVAL_MINUTES=30

# ──────────────────────────────────────────────────────────────────
# NOTIFICATION: EMAIL (SMTP)
# ──────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_ADDRESS=

# ──────────────────────────────────────────────────────────────────
# NOTIFICATION: TELEGRAM BOT API
# ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ──────────────────────────────────────────────────────────────────
# REPORT DISTRIBUTION: WHATSAPP BUSINESS CLOUD API
# ──────────────────────────────────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ──────────────────────────────────────────────────────────────────
# REPORT DISTRIBUTION: DISCORD WEBHOOK
# ──────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ──────────────────────────────────────────────────────────────────
# APPLICATION LOGGING
# ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Max log file size before rotation (bytes); default 100 MB
LOG_MAX_BYTES=104857600
# Number of rotated log files to retain
LOG_BACKUP_COUNT=10
# Syslog forwarding (disabled by default)
SYSLOG_ENABLED=false
SYSLOG_HOST=
SYSLOG_PORT=514

# ──────────────────────────────────────────────────────────────────
# TIMEFRAME DEFAULTS
# ──────────────────────────────────────────────────────────────────
DEFAULT_REFRESH_INTERVAL_SECONDS=60
# Session idle timeout in hours before automatic logout
SESSION_IDLE_TIMEOUT_HOURS=4

# ──────────────────────────────────────────────────────────────────
# OPTIONAL FEATURES
# ──────────────────────────────────────────────────────────────────
# Enable Prometheus /metrics endpoint
METRICS_ENABLED=false
